NOTE_EMAIL=your-email@example.com
NOTE_PASSWORD=your_password_here
ANTHROPIC_API_KEY=your_key_here
LP_URL=https://nvcloud-lp.pages.dev/

# ---------- X (Twitter) API v2 — OAuth 1.0a User Context ----------
# 取得手順: README.md の「X API 認証セットアップ」節参照
# Developer Portal: https://developer.x.com/en/portal/dashboard
# Free tier: 1,500 posts/月 / 100 reads/月、Project 1つまで
#
# 5 項目すべて必須。App-only Bearer (X_BEARER_TOKEN) だけでは投稿不可で、
# OAuth 1.0a User Context の 4 項目 (API Key/Secret + Access Token/Secret) を
# Developer Portal の「Keys and tokens」タブから取得して揃える必要あり。
X_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAA...
X_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx
X_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
X_ACCESS_TOKEN=1234567890-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
X_ACCESS_TOKEN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
